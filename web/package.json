{
  "name": "duckdb-component-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Run the DuckDB Wasm component in JS runtimes / the browser via wasi-polyfill",
  "scripts": {
    "copy-wasm": "cp ../target/wasm32-wasip2/release/duckdb_core_component.wasm public/ && cp ../artifacts/extensions/sample_extension.wasm public/",
    "predev": "npm run copy-wasm",
    "dev": "vite",
    "verify": "npm run copy-wasm && node verify.mjs",
    "verify-ext": "npm run copy-wasm && node verify.mjs /index-ext.html"
  },
  "dependencies": {
    "@tegmentum/wasi-polyfill": "file:../../../wasi-polyfill",
    "@bytecodealliance/jco": "^1.23.0"
  },
  "devDependencies": {
    "vite": "^7.0.0",
    "playwright": "^1.49.0"
  }
}
