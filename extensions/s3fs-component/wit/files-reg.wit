package duckdb:extension;

use types;

// httpfs M2 files backend registration surface. A component that backs remote
// file reads (an http(s) fetcher) registers here in load(), then implements the
// `file-dispatch` export the host calls to open / read / close URLs. Mirrors
// `storage.register-storage`.
interface files-reg {
  use types.{duckerror};

  // Declared in load() to mark this component as the files backend.
  register-files: func(callback-handle: u32) -> result<u32, duckerror>;
}
