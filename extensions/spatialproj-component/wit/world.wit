package duckdb:extension@2.2.0;

use runtime;
use callback-dispatch;
use config;
use logging;
use catalog;
use files;
use guest;

// spatialproj: a duckdb:extension component that ALSO imports the
// `compose:dynlink/linker` host capability. It registers a scalar
// `ST_Transform(wkt, from_srid, to_srid) -> VARCHAR` whose body resolves the
// shared, resident `gdal` provider and invokes its `transform` method
// (SpatialRef::from_epsg + a coordinate Transform + a wkt/geo-types coordinate
// walk), returning the reprojected WKT.
//
// GDAL/PROJ + proj.db live ONCE in the resident gdal-provider; the host loads
// it once and shares it across every geo extension, instead of GDAL being
// wac-inlined into each consumer at build time.
world spatialproj {
  import runtime;
  import config;
  import logging;
  import catalog;
  import files;

  // The shared-provider bridge: host-resolved, host-owned. Satisfied at
  // exec time by ducklink-host's compose:dynlink/linker implementation,
  // which forwards invoke() bytes to the resident gdal provider.
  import compose:dynlink/linker@0.1.0;

  export guest;
  export callback-dispatch;
}
