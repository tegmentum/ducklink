package duckdb:extension@3.1.0;

use runtime;
use callback-dispatch;
use config;
use logging;
use catalog;
use files;
use query;
use guest;

world duckdb-extension {
  import runtime;
  import config;
  import logging;
  import catalog;
  import files;
  // v1.1: the live-query host import for catalog-name completion (table/column
  // suggestions). The host always PROVIDES it; importing it is what makes
  // sql_complete able to read the live catalog.
  import query;
  export guest;
  export callback-dispatch;
}
