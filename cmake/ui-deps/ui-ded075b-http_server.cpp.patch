+#ifdef __wasi__
+extern "C" {
+// Handle one UI HTTP request through the started singleton. Returns a malloc'd
+// buffer (free with duckdb_ui_free) laid out as:
+//   u32 status | u32 ctype_len | ctype | u32 body_len | body
+// Returns nullptr with *out_len = 0 if the UI server hasn't been started.
+uint8_t *duckdb_ui_handle_request(const char *method, const char *path,
+                                  const char *headers, const uint8_t *body,
+                                  size_t body_len, size_t *out_len) {
+  uint16_t status = 0;
+  std::string ctype;
+  bool ok = false;
+  std::string resp = duckdb::ui::HttpServer::BridgeHandle(
+      method ? method : "GET", path ? path : "/", headers ? headers : "",
+      std::string(reinterpret_cast<const char *>(body), body_len), status, ctype,
+      ok);
+  if (!ok) {
+    *out_len = 0;
+    return nullptr;
+  }
+  uint32_t ctype_len = static_cast<uint32_t>(ctype.size());
+  uint32_t resp_len = static_cast<uint32_t>(resp.size());
+  size_t total = 12 + ctype_len + resp_len;
+  auto *buf = static_cast<uint8_t *>(malloc(total));
+  size_t off = 0;
+  auto put_u32 = [&](uint32_t v) {
+    memcpy(buf + off, &v, 4);
+    off += 4;
+  };
+  put_u32(status);
+  put_u32(ctype_len);
+  memcpy(buf + off, ctype.data(), ctype_len);
+  off += ctype_len;
+  put_u32(resp_len);
+  memcpy(buf + off, resp.data(), resp_len);
+  *out_len = total;
+  return buf;
+}
+
+void duckdb_ui_free(uint8_t *buf) { free(buf); }
+}
+#endif // __wasi__
