+#ifdef __wasi__
+// --- wasm bridge ----------------------------------------------------------
+// The native host owns the listening socket and forwards each request here.
+std::string HttpServer::HandleRequest(const std::string &method,
+                                      const std::string &path,
+                                      const std::string &headers,
+                                      const std::string &body,
+                                      uint16_t &out_status,
+                                      std::string &out_ctype) {
+  httplib::Request req;
+  req.method = method;
+  req.path = path;
+  req.body = body;
+  // parse "Key: Value\n"-delimited headers
+  std::istringstream hs(headers);
+  std::string line;
+  while (std::getline(hs, line)) {
+    if (!line.empty() && line.back() == '\r') {
+      line.pop_back();
+    }
+    auto colon = line.find(':');
+    if (colon == std::string::npos) {
+      continue;
+    }
+    std::string key = line.substr(0, colon);
+    std::string val = line.substr(colon + 1);
+    auto s = val.find_first_not_of(" \t");
+    val = (s == std::string::npos) ? std::string() : val.substr(s);
+    req.headers.emplace(key, val);
+  }
+
+  httplib::Response res;
+  res.status = 200;
+  httplib::ContentReader content_reader(
+      [&](httplib::ContentReceiver receiver) -> bool {
+        return body.empty() ? true : receiver(body.data(), body.size());
+      },
+      [&](httplib::MultipartContentHeader, httplib::ContentReceiver) -> bool {
+        return true;
+      });
+
+  if (method == "POST" && path == "/ddb/run") {
+    HandleRun(req, res, content_reader);
+  } else if (method == "POST" && path == "/ddb/tokenize") {
+    HandleTokenize(req, res, content_reader);
+  } else if (method == "POST" && path == "/ddb/interrupt") {
+    HandleInterrupt(req, res);
+  } else if (method == "GET" && path == "/info") {
+    HandleGetInfo(req, res);
+  } else if (method == "GET" && path == "/localToken") {
+    HandleGetLocalToken(req, res);
+  } else if (method == "GET" && path == "/localEvents") {
+    // SSE: the catalog watcher is disabled on wasm, so no push events.
+    res.set_content("", "text/event-stream");
+  } else {
+    HandleGet(req, res); // assets/proxy (the host normally handles these)
+  }
+
+  out_status = res.status > 0 ? static_cast<uint16_t>(res.status) : 200;
+  out_ctype = res.get_header_value("Content-Type");
+  if (out_ctype.empty()) {
+    out_ctype = "application/octet-stream";
+  }
+  return res.body;
+}
+
+std::string HttpServer::BridgeHandle(const std::string &method,
+                                     const std::string &path,
+                                     const std::string &headers,
+                                     const std::string &body,
+                                     uint16_t &out_status, std::string &out_ctype,
+                                     bool &ok) {
+  if (!server_instance) {
+    ok = false;
+    return std::string();
+  }
+  ok = true;
+  return server_instance->HandleRequest(method, path, headers, body, out_status,
+                                        out_ctype);
+}
+#endif // __wasi__
