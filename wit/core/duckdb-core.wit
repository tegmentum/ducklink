package duckdb:component;

use duckdb:extension/config@2.1.0;
use duckdb:extension/logging@2.1.0;
use duckdb:extension/runtime@2.1.0;
use duckdb:extension/types@2.1.0;
use duckdb:extension/callback-dispatch@2.1.0;
use wasi:cli/environment@0.2.6;
use wasi:cli/stdout@0.2.6;
use wasi:cli/stderr@0.2.6;
use wasi:filesystem/preopens@0.2.6;
use wasi:io/streams@0.2.6;

interface database {
    use types.{capabilitykind, columndef, duckerror, duckvalue};

    /// Represents an open DuckDB connection.
    resource connection;

    /// Row of typed DuckDB values (`duckvalue.none` represents SQL NULL).
    type row = list<duckvalue>;

    /// Represents a buffered query result.
    record query-result {
        columns: list<columndef>,
        rows: list<row>,
    }

    /// Streaming cursor for incremental result consumption.
    resource result-stream {
        /// Column layout for the underlying query.
        schema: func() -> list<columndef>;

        /// Fetches up to `max-rows` rows or `none` once the stream is exhausted.
        next: func(max-rows: u32) -> result<option<list<row>>, duckerror>;

        /// Releases resources associated with the stream.
        close: func();
    }

    /// A SQL statement compiled once for repeated parameterized execution.
    /// Parameters are positional (`$1`, `$2`, ... or `?`).
    resource prepared-statement {
        /// Number of parameters the statement expects.
        parameter-count: func() -> u32;

        /// Binds `params` to the positional parameters in order and runs the
        /// statement, returning all rows eagerly. May be called repeatedly with
        /// different parameters; each call rebinds from scratch.
        execute: func(params: list<duckvalue>) -> result<query-result, duckerror>;
    }

    /// Bulk row insertion into an existing table — much faster than running
    /// individual INSERT statements.
    resource appender {
        /// Appends one row; `values` bind positionally to the table's columns.
        append-row: func(values: list<duckvalue>) -> result<_, duckerror>;

        /// Flushes buffered rows to the table.
        flush: func() -> result<_, duckerror>;

        /// Flushes and closes the appender (also performed when dropped).
        close: func() -> result<_, duckerror>;
    }

    /// Opens a DuckDB database. Pass `none` for an in-memory database.
    open: func(path: option<string>) -> result<connection, string>;

    /// Opens a DuckDB database applying the given configuration options (e.g.
    /// `access_mode=read_only`, `threads=4`, `max_memory=1GB`) before connecting.
    /// Each option is a `(name, value)` pair; an unknown name or invalid value
    /// fails the open.
    open-with-config: func(
        path: option<string>,
        options: list<tuple<string, string>>,
    ) -> result<connection, string>;

    /// Explicitly closes the database connection.
    close: func(conn: connection);

    /// Interrupts any running query on the provided connection.
    interrupt: func(conn: borrow<connection>);

    /// Executes a SQL statement and returns all typed rows eagerly.
    execute: func(conn: borrow<connection>, sql: string) -> result<query-result, duckerror>;

    /// Executes a SQL statement and returns a streaming cursor.
    open-stream: func(conn: borrow<connection>, sql: string) -> result<result-stream, duckerror>;

    /// Compiles a SQL statement for repeated parameterized execution.
    prepare: func(conn: borrow<connection>, sql: string) -> result<prepared-statement, duckerror>;

    /// Runs a query and returns the full result encoded as an Arrow IPC stream
    /// (schema message followed by record-batch messages). Consumers decode it
    /// with any Arrow implementation (e.g. apache-arrow in JS, arrow in Rust).
    /// True zero-copy is not possible across the component boundary, so the
    /// columnar buffers are serialized once into this byte stream.
    query-arrow: func(conn: borrow<connection>, sql: string) -> result<list<u8>, duckerror>;

    /// Creates an appender for bulk insertion into `table` (in `schema`, or the
    /// default schema when `none`).
    create-appender: func(
        conn: borrow<connection>,
        schema: option<string>,
        table: string,
    ) -> result<appender, duckerror>;

    /// Registers metadata about an extension along with the capabilities it intends to use.
    register-extension: func(name: string, requires: list<capabilitykind>) -> result<bool, string>;

    /// Returns the currently registered extensions and their declared capabilities.
    list-registered-extensions: func() -> list<extension-info>;

    /// Extension metadata captured during registration.
    record extension-info {
        name: string,
        requires: list<capabilitykind>,
    }

    /// One response from the DuckDB UI extension's bridged HTTP handler.
    record ui-response {
        status: u16,
        /// All response headers as a "Key: Value\n"-delimited block.
        headers: string,
        body: list<u8>,
    }

    /// Handle one DuckDB UI HTTP request through the (static) `ui` extension's
    /// HttpServer, which the native host bridges to (httplib can't listen() in
    /// the wasip2 sandbox). `start-ui-server` must have been run first; returns
    /// none if the UI server isn't started. `headers` is a "Key: Value\n" block.
    handle-ui-request: func(method: string, path: string, headers: string, body: list<u8>) -> option<ui-response>;
}

interface host-extension-loader {
    /// Request the host to load a componentized DuckDB extension. Returns true if handled.
    request-load: func(name: string) -> bool;
}

interface extension-loader-hooks {
    use types.{logicaltype, columndef, funcflags};

    /// Mirrors `duckdb:extension/runtime.funcarg` without pulling the runtime interface in.
    record func-arg {
        name: option<string>,
        logical: logicaltype,
    }

    /// Mirrors `duckdb:extension/runtime.funcopts`.
    record func-opts {
        description: option<string>,
        tags: list<string>,
        attributes: funcflags,
    }

    /// Mirrors `duckdb:extension/runtime.extopts`.
    record ext-opts {
        description: option<string>,
        tags: list<string>,
    }

    /// Pending scalar function registration captured during extension load.
    record scalar-registration {
        name: string,
        arguments: list<func-arg>,
        returns: logicaltype,
        callback-handle: u32,
        options: option<func-opts>,
    }

    /// Pending table function registration captured during extension load.
    record table-registration {
        name: string,
        arguments: list<func-arg>,
        columns: list<columndef>,
        callback-handle: u32,
        options: option<ext-opts>,
    }

    /// Pending aggregate function registration captured during extension load.
    record aggregate-registration {
        name: string,
        arguments: list<func-arg>,
        returns: logicaltype,
        callback-handle: u32,
        options: option<func-opts>,
    }

    /// Pending macro registration captured during extension load.
    record macro-registration {
        schema: string,
        name: string,
        parameters: list<string>,
        definition-sql: string,
    }

    /// Pending replacement-scan registration captured during extension load.
    /// Maps file extensions to a previously registered table function (resolved
    /// to its name by the host) so `FROM 'file.ext'` rewrites to that function.
    record replacement-scan-registration {
        extensions: list<string>,
        function-name: string,
    }

    /// Pending logical-type (named type alias) registration captured during
    /// extension load. `physical` is a SQL type expression, e.g. "INTEGER".
    record logical-type-registration {
        name: string,
        physical: string,
    }

    /// Pending cast registration captured during extension load. `source` and
    /// `target` are SQL type names; `callback-handle` dispatches the transform.
    record cast-registration {
        source: string,
        target: string,
        callback-handle: u32,
    }

    /// Bundled response describing all pending registrations.
    record pending-registrations {
        scalars: list<scalar-registration>,
        tables: list<table-registration>,
        aggregates: list<aggregate-registration>,
        macros: list<macro-registration>,
        replacement-scans: list<replacement-scan-registration>,
        logical-types: list<logical-type-registration>,
        casts: list<cast-registration>,
    }

    /// Returns the pending registration requests the host captured while the extension was loading.
    /// The host drains its internal queues on every call.
    get-pending-registrations: func() -> pending-registrations;
}

world libduckdb {
    import wasi:cli/environment@0.2.6;
    import wasi:cli/stdout@0.2.6;
    import wasi:cli/stderr@0.2.6;
    import wasi:filesystem/preopens@0.2.6;
    import wasi:filesystem/types@0.2.6;
    import wasi:io/streams@0.2.6;
    import host-extension-loader;
    import extension-loader-hooks;
    import duckdb:extension/callback-dispatch@2.1.0;
    import tvm:memory/manager@0.1.0;
    import tvm:memory/bytes@0.1.0;

    export database;
    export duckdb:extension/config@2.1.0;
    export duckdb:extension/logging@2.1.0;
    export duckdb:extension/runtime@2.1.0;
}
