      "aot": false,
      "embedded": false,
      "note": "Core + extension as separate components, host-resolver/WIT-dispatched, Cranelift-compiled at instantiation. The current shipped wasm path."
    },
    {
      "id": "wasm-dynamic-aot",
      "title": "WASM DYNAMIC, AOT",
      "kind": "wasm",
      "aot": true,
      "embedded": false,
      "note": "Same dynamic dispatch, but core + cli loaded from wasmtime-precompiled .cwasm (deserialize, no compile). Isolates the one-time compile cost from steady-state throughput."
