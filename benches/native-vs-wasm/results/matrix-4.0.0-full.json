  "configs": [
    {
      "id": "native",
      "title": "NATIVE (bundled DuckDB + native ducklink ext)",
      "kind": "native",
      "aot": false,
      "embedded": false,
      "note": "Baseline. Native engine builds DataChunks; reg_duckdb marshals across WIT into the component (embedded wasmtime). The extension algorithm is still wasm."
    },
    {
      "id": "wasm-dynamic-noaot",
      "title": "WASM DYNAMIC, no-AOT",
      "kind": "wasm",
      "aot": false,
      "embedded": false,
      "note": "Core + extension as separate components, host-resolver/WIT-dispatched, Cranelift-compiled at instantiation. The current shipped wasm path."
    },
    {
      "id": "wasm-dynamic-aot",
      "title": "WASM DYNAMIC, AOT",
      "kind": "wasm",
      "aot": true,
      "embedded": false,
      "note": "Same dynamic dispatch, but core + cli loaded from wasmtime-precompiled .cwasm (deserialize, no compile). Isolates the one-time compile cost from steady-state throughput."
    },
    {
      "id": "wasm-embedded-noaot",
      "title": "WASM EMBEDDED, no-AOT",
      "kind": "wasm",
      "aot": false,
      "embedded": true,
      "note": "Extension compiled INTO the core (embed framework: registered as a native scalar, no cross-component WIT dispatch boundary), compiled at instantiation."
    },
    {
      "id": "wasm-embedded-aot",
      "title": "WASM EMBEDDED, AOT",
      "kind": "wasm",
      "aot": true,
      "embedded": true,
      "note": "Embedded + precompiled .cwasm. The expected near-native upper bound once the columnar @4.0.0 ABI lands."
    }
  ],
